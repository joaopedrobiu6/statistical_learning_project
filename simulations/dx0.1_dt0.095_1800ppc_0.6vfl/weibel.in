{
!  ndump_fac_raw = 1,
ndump_fac = 1,
!  ndump_fac_ave = 1,
!  n_ave(1:1) = 4,4,
ndump_fac_pha = 1,
ndump_fac_ene = 1,

! reports = "charge", !"j1", !"j2","j3", "ene",
! rep_udist = "vfl1", "vfl2", "vfl3", "T11", "T12", !"T13", "T23", "T22", "T33", !"P11", "P12", "P13", "P23", "P22", "P33",

ps_xmin(1:1) =  0.0,  ps_pmin(1:3) = -3, -3, -3,
ps_xmax(1:1) =  12.8, ps_pmax(1:3) =  3, 3, 3,
ps_nx(1:1)   = 128, ps_np(1:3)   =  256,  256,  256,

!  if_ps_p_auto(1:3) = .true.,.true.,.true.,

ps_ngamma = 256,

!  if_ps_gamma_auto = .true.,

ps_gammamin = 1.0,
ps_gammamax = 1.5,

! phasespaces = "p1x1","p2x1",!"gx1",
}


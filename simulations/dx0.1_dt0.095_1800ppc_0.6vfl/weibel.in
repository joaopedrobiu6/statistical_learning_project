!*******************************

!----------information for this species  ----------
species
{
name="positrons-down",
num_par_max = 1000000,
rqm=1.0,
num_par_x(1:1) = 1800, 
add_tag = .true.,
}

udist
{
uth(1:3) = 0.01d0, 0.01d0, 0.01d0,
ufl(1:3)=  0.0d0 , -0.6d0 , 0.0d0 ,
}
profile
{
density = 0.5,
}
!----------boundary conditions for this species----------
spe_bound
{
}

!----------diagnostic for this species----------
diag_species
{
!  ndump_fac_raw = 1,
ndump_fac = 1,
!  ndump_fac_ave = 1,
!  n_ave(1:2) = 4,4,
ndump_fac_pha = 1,
ndump_fac_ene = 1,

! reports = "charge", !"j1", !"j2","j3", "ene",
! rep_udist = "vfl1", "vfl2", "vfl3", "T11", "T12", !"T13", "T23", "T22", "T33", !"P11", "P12", "P13", "P23", "P22", "P33",

ps_xmin(1:1) =  0.0, ps_pmin(1:3) = -3, -3, -3,
ps_xmax(1:1) =  12.8, ps_pmax(1:3) =  3, 3, 3,
ps_nx(1:1)   = 128, ps_np(1:3)   =  256,  256,  256,

!  if_ps_p_auto(1:3) = .true.,.true.,.true.,

ps_ngamma = 256,

!  if_ps_gamma_auto = .true.,

ps_gammamin = 1.0,
ps_gammamax = 1.5,

! phasespaces = "p1x1","p2x1",!"gx1",
}

current
{
}

!-------------smooth for currents-------------
smooth
{
type(1:1) = "5pass",
}

